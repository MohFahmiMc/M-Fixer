<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:orientation="vertical"
    android:padding="15dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">
        <Button android:id="@+id/btnUndo" android:layout_width="wrap_content" android:layout_height="40dp" android:text="Undo" android:backgroundTint="#333"/>
        <Button android:id="@+id/btnRedo" android:layout_width="wrap_content" android:layout_height="40dp" android:text="Redo" android:layout_marginStart="10dp" android:backgroundTint="#333"/>
    </LinearLayout>
    <EditText
        android:id="@+id/etCode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000"
        android:gravity="top"
        android:textColor="#00FF00"
        android:fontFamily="monospace"
        android:padding="12dp"
        android:hint="Start scripting..."
        android:textColorHint="#444"/>
</LinearLayout>
